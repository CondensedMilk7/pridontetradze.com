---
layout: "base.njk"
---
{%- set cat = tags | category -%}
{%- set isGeo = title | hasGeorgian -%}

<div class="ledger">
  <article>
    <section class="section article-header">
      <div class="section__index article__meta">
        <a class="article__back" href="/blog/">← blog</a>
        <span class="article__cat">{{ cat }}</span>
        <span class="article__date">{{ page.date | postDate }}</span>
        <span class="article__time">{{ page.inputPath | readingTime }} min{% if isGeo %} · ქა{% endif %}</span>
      </div>
      <div class="section__body">
        <h1 class="article__title{% if isGeo %} geo{% endif %}">{{ title }}</h1>
        {% if description %}
          <p class="article__dek measure{% if isGeo %} geo{% endif %}">{{ description }}</p>
        {% endif %}
        {% if image %}
          <div class="article__cover">
            <img src="{{ image }}" alt="{{ imageAlt or title }}" fetchpriority="high" loading="eager" />
          </div>
        {% endif %}
      </div>
    </section>

    {{ content | articleLedger | safe }}

    {% if "academic" in tags %}
      <section class="section article-cite">
        <div class="section__index">
          <p class="section__eyebrow" aria-hidden="true">cite this</p>
        </div>
        <div class="section__body">
          <div class="citation-box">
            <p>
              {{ author | citeAuthor }} ({{ page.date | citeYear }}).
              <strong>{{ title }}</strong>. pridontetradze.com. Retrieved from
              {{ page.url | absoluteUrl(site.url) }}
            </p>
          </div>
        </div>
      </section>
    {% endif %}
  </article>
</div>
