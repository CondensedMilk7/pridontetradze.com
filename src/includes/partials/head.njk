<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  {# Set the theme on <html> before any paint to avoid a flash of the wrong theme. #}
  <script>
    (function () {
      try {
        var t =
          localStorage.getItem("theme") ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        if (t === "light") document.documentElement.classList.add("light");
      } catch (e) {}
    })();
  </script>

  {# --- Fonts --- #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=DM+Mono:wght@400;500&family=Noto+Sans+Georgian:wght@400;500;600;700&display=swap" rel="stylesheet">

  {# --- Design tokens + base (always) --- #}
  <link rel="stylesheet" href="/styles/tokens.css" />
  <link rel="stylesheet" href="/styles/main.css" />

  {# --- Page-specific styles --- #}
  {% if page.url === "/" %}
    <link rel="stylesheet" href="/styles/elements/home.css" />
  {% endif %}
  {% if "/about" in page.url %}
    <link rel="stylesheet" href="/styles/elements/about.css" />
  {% endif %}
  {% if page.url === "/blog/" or "/tags/" in page.url %}
    <link rel="stylesheet" href="/styles/elements/writing.css" />
  {% endif %}
  {% if "/blog/" in page.url and page.url !== "/blog/" %}
    <link rel="stylesheet" href="/styles/elements/article.css" />
    <link rel="stylesheet" href="/styles/highlight-theme.css" />
  {% endif %}
  {% if "/cats" in page.url %}
    <link rel="stylesheet" href="/styles/elements/cats.css" />
    <script defer src="/scripts/cats.js"></script>
  {% endif %}
  {% if "/music" in page.url %}
    <link rel="stylesheet" href="/styles/elements/music.css" />
    <script src="https://kit.fontawesome.com/5e50b52fe3.js" crossorigin="anonymous"></script>
    <script src="/wavesurfer.js" type="module"></script>
    <script defer src="/scripts/music.js" type="module"></script>
  {% endif %}

  <link rel="icon" href="/assets/icons/favicon.ico" sizes="48x48">
  <link rel="icon" type="image/svg+xml" href="/assets/icons/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/icons/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/icons/favicon-16x16.png">
  <link rel="apple-touch-icon" href="/assets/icons/apple-touch-icon.png">

  <script type="module" src="/scripts/main.js"></script>

  <meta property="og:title" content="{{ title }}">
  <meta property="og:image" content="{{ image }}">
  <meta property="og:description" content="{{ description }}">
  <meta name="description" content="{{ description }}">
  <meta name="theme-color" content="#201e1b">
  <title>{{ title }} {% if title %} | {% endif %} Pridon Tetradze</title>
</head>
