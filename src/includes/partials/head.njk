<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  {# Set the theme on <html> before any paint to avoid a flash of the wrong theme. #}
  <script>
    (function () {
      try {
        var t =
          localStorage.getItem("theme") ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        if (t === "light") document.documentElement.classList.add("light");
      } catch (e) {}
    })();
  </script>

  {# --- Fonts --- #}
  {# Load Google Fonts non-render-blocking: the print media type keeps the
     stylesheet off the critical path, then onload flips it to all. display=swap
     paints fallback text immediately, so no new flash is introduced. #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=DM+Mono:wght@400;500&family=Noto+Sans+Georgian:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=DM+Mono:wght@400;500&family=Noto+Sans+Georgian:wght@400;500;600;700&display=swap" rel="stylesheet"></noscript>

  {# --- Design tokens + base (always), inlined + minified to avoid render-blocking requests --- #}
  <style>{{ "tokens.css" | inlineCss | safe }}{{ "main.css" | inlineCss | safe }}</style>

  {# --- Palette lab (local only, PALETTE_LAB=1): alt palettes + pre-paint switch script --- #}
  {% if env.paletteLab %}
    <style>{{ "palette-lab.css" | inlineCss | safe }}</style>
    <script>{{ "palette/index.js" | inlineJs | safe }}</script>
  {% endif %}

  {# --- Page-specific styles (inlined) --- #}
  {% if page.url === "/" %}
    <style>{{ "elements/home.css" | inlineCss | safe }}</style>
  {% endif %}
  {% if "/about" in page.url %}
    <style>{{ "elements/about.css" | inlineCss | safe }}</style>
  {% endif %}
  {% if page.url === "/blog/" or "/tags/" in page.url %}
    <style>{{ "elements/writing.css" | inlineCss | safe }}</style>
  {% endif %}
  {% if "/blog/" in page.url and page.url !== "/blog/" %}
    <style>{{ "elements/article.css" | inlineCss | safe }}{{ "highlight-theme.css" | inlineCss | safe }}</style>
  {% endif %}
  {% if "/cats" in page.url %}
    <style>{{ "elements/cats.css" | inlineCss | safe }}</style>
    <script defer src="/scripts/cats.js"></script>
  {% endif %}
  {% if "/music" in page.url %}
    <style>{{ "elements/music.css" | inlineCss | safe }}</style>
    <script src="https://kit.fontawesome.com/5e50b52fe3.js" crossorigin="anonymous"></script>
    <script src="/wavesurfer.js" type="module"></script>
    <script defer src="/scripts/music.js" type="module"></script>
  {% endif %}

  <link rel="icon" href="/assets/icons/favicon.ico" sizes="48x48">
  <link rel="icon" type="image/svg+xml" href="/assets/icons/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/icons/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/icons/favicon-16x16.png">

  <script>{{ "main.js" | inlineJs | safe }}</script>

  <meta property="og:title" content="{{ title }}">
  <meta property="og:image" content="{{ image }}">
  <meta property="og:description" content="{{ description }}">
  <meta name="description" content="{{ description }}">
  <meta name="theme-color" content="#17131c">
  <title>{{ title }} {% if title %} | {% endif %} Pridon Tetradze</title>
</head>
