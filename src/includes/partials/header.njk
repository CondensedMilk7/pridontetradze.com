<header class="site-header">
  <div class="site-header__inner container">
    <a class="wordmark" href="/">
      <span class="wordmark__dot" aria-hidden="true"></span>
      <span>Pridon's corner <span class="wordmark__place">· {{ page.url | shellPath }}</span></span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a class="site-nav__link" href="/" {% if page.url === "/" %}aria-current="page"{% endif %}>home</a>
      <a class="site-nav__link" href="/about/" {% if "/about" in page.url %}aria-current="page"{% endif %}>about</a>
      <a class="site-nav__link" href="/blog/" {% if "/blog" in page.url or "/tags" in page.url %}aria-current="page"{% endif %}>blog</a>
      {% include "theme-toggle.njk" %}
      <button class="menu-toggle" id="menu-open" type="button" aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<dialog id="mobile-menu" class="mobile-menu" aria-label="Site menu">
  <div class="mobile-menu__bar container">
    <span class="wordmark">
      <span class="wordmark__dot" aria-hidden="true"></span>
      <span>Pridon's corner</span>
    </span>
    <div class="mobile-menu__actions">
      {% include "theme-toggle.njk" %}
      <button class="menu-toggle" id="menu-close" type="button" aria-label="Close menu">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>
  </div>

  <nav class="mobile-menu__nav container" aria-label="Pages">
    <a href="/" {% if page.url === "/" %}aria-current="page"{% endif %}><span class="mobile-menu__num" aria-hidden="true">00</span>Home</a>
    <a href="/about/" {% if "/about" in page.url %}aria-current="page"{% endif %}><span class="mobile-menu__num" aria-hidden="true">01</span>About</a>
    <a href="/blog/" {% if "/blog" in page.url or "/tags" in page.url %}aria-current="page"{% endif %}><span class="mobile-menu__num" aria-hidden="true">02</span>Blog</a>
    <a href="/cats/" {% if "/cats" in page.url %}aria-current="page"{% endif %}><span class="mobile-menu__num" aria-hidden="true">03</span>Cats</a>
    <a href="/music/" {% if "/music" in page.url %}aria-current="page"{% endif %}><span class="mobile-menu__num" aria-hidden="true">04</span>Music</a>
  </nav>

  <div class="mobile-menu__find container">
    <p class="kicker">find me</p>
    <ul class="mobile-menu__links">
      <li><a href="mailto:{{ cv.contact.email }}">mail</a></li>
      <li><a href="{{ cv.contact.linkedin }}">linkedin</a></li>
      <li><a href="{{ cv.contact.github }}">github</a></li>
    </ul>
  </div>

  <footer class="mobile-menu__footer container">
    <span>&copy; {% year %}</span>
    <span class="prayer geo">
      <span class="cross" aria-hidden="true">{%- include "cross.njk" -%}</span>
      უფალო შეგვიწყალენ
    </span>
  </footer>
</dialog>
