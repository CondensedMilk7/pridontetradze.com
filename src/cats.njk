---
title: "Cat Gallery"
layout: "base.njk"
description: "A collection of my adorable cat pictures."
image: "/assets/images/cover.jpg"
---

<div class="ledger">
  <section class="section">
    <div class="section__index">— gallery</div>
    <div class="section__body">
      <h1 class="gallery__title">Cats</h1>
      <p class="gallery__sub measure">The good stuff — an unserious, ongoing archive of the cats I live with.</p>
    </div>
  </section>

  <section class="section">
    <div class="section__index gallery__count">
      <span>photos</span>
      <span>{% if catGallery.length < 10 %}0{% endif %}{{ catGallery.length }}</span>
    </div>
    <div class="section__body">
      <div class="cats-gallery">
        {%- for cat in catGallery -%}
        <figure class="cat-card">
          <div class="cat-image">
            <img src="{{ cat.image }}" alt="{{ cat.alt }}" loading="lazy">
          </div>
          <figcaption class="cat-caption">
            <span class="cat-name">{{ cat.name }}</span>
            <span class="cat-trait">{{ cat.description }}</span>
          </figcaption>
        </figure>
        {%- endfor -%}
      </div>
    </div>
  </section>

  <div id="cat-modal" class="cat-modal">
    <div class="modal-content">
      <span class="modal-close" role="button" aria-label="Close">&times;</span>
      <img id="modal-image" src="" alt="">
    </div>
  </div>
</div>
